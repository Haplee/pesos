{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "gimnasia.png", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/gimnasia.png", "dest": "/gimnasia.png" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}